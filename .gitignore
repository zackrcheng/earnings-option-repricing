*.csv
*.parquet
*.dta
*.sas7bdat
*.feather
*.pkl
*.pickle
data/raw/
data/processed/
outputs/

# Allow small committed outputs (remove the ! lines if you want nothing committed)
!outputs/.gitkeep
!outputs/tables/.gitkeep
!outputs/figures/.gitkeep

